GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string for real login and Mongo memory.
# Replace the username, password, cluster, and database name with your own values.
MONGODB_URI=mongodb+srv://your_user:your_password@your-cluster.mongodb.net/bytebot?retryWrites=true&w=majority
MONGODB_DB_NAME=bytebot

# Make this long and random before hosting.
JWT_SECRET_KEY=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional search and voice tools.
# Keep these empty until you are ready to enable those endpoints.
SERPAPI_API_KEY=
OPENAI_API_KEY=

# Free local Whisper settings for voice input.
# The first transcription downloads the model once. tiny is fastest on CPU.
LOCAL_WHISPER_MODEL=tiny
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
# Leave blank to auto-detect language, or use en/hi/etc.
LOCAL_WHISPER_LANGUAGE=

# Add local frontend and deployed frontend origins.
# Example hosted value:
# FRONTEND_ORIGINS=http://127.0.0.1:8028,http://localhost:8028,https://your-site.vercel.app
FRONTEND_ORIGINS=http://127.0.0.1:8028,http://localhost:8028,null
